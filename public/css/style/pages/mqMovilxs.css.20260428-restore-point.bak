@media (max-width: 576px) {

    .titulo {
        height: fit-content;
        padding: 16px;
    }

    .titulo h1 {
        font-size: var(--tamanoTituloMovileXS);
    }

    .titulo p {
        padding-left: 1ch;
        gap: 10px;
        font-size: var(--tamanoTextoMovileXS);
    }

    .contenidoMain {
        width: 100%;
        margin-left: 0;
        height: auto;
        gap: 16px;
        padding-bottom: 16px;
        border-top: none;
    }

    .nav {
        font-size: var(--tamanoEnlaceMovileXS);
        width: 100%;
    }

    .nav ul {
        margin-left: 14px;
    }

    .nav li {
        padding: 10px 0;
    }

    .asideLeft {
        position: static;
        left: auto;
        top: auto;
        transform: none;
        width: 100%;
        height: auto;
        padding: 0;
        flex-direction: row;
        justify-content: stretch;
        background-color: transparent;
    }

    .seccionAboutMe{
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: justify;
        margin-left: auto;
        width: 100%;
        padding: 16px;
        margin-top: auto;
        position: relative;
        top: auto;
    }
    .seccionAboutMe h2 {
        font-size: 1.3rem;
        font-family: var(--fuenteTexto);
        font-weight: var(--grosorTitulo);
        text-decoration: underline dotted var(--colorBorde);
        margin-bottom: 16px;
    }
    .seccionAboutMe p {
        font-size: 0.8rem;
        font-family: var(--fuenteTexto);
        font-weight: var(--grosorTexto);
        text-transform: uppercase;
        text-align: justify;
        padding: 8px;
    }

    .articles {
        width: 100%;
        padding: 16px;
        margin-left: 0;
        position: static;
        top: auto;
        gap: 18px;
    }

    .articles section {
        padding: 14px 16px;
    }

    .articles h2 {
        font-size: 1.3rem;
    }

    .articles p,
    .articles li,
    .articles td,
    .articles th,
    .articles blockquote {
        font-size: var(--tamanoTextoMovileXS);
    }

    .articles table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
    }

    .articles .articleSource,
    .articles .articleSource:visited {
        width: 100%;
        min-width: 0;
        font-size: var(--tamanoEnlaceMovileXS);
    }

    .asideLeft button {
        writing-mode: initial;
        flex: 1;
        height: auto;
        min-height: 48px;
        font-size: var(--tamanoEnlaceMovileXS);
        border-bottom: 1px solid var(--colorBorde);
    }

    .asideLeft button.active {
        border-left: none;
        border-bottom: 2px solid var(--colorBorde);
    }

    .textoAbout {
        padding: 10px;
        margin-left: 0;
        width: 100%;
    }

    .textoAbout p {
        font-size: var(--tamanoTextoMovileXS);
    }

    /*Formulario de contacto*/
    .seccionContact {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: justify;
        margin-left: auto;
        width: 100%;
        padding: 24px;
        /* position: relative; */
        top: auto;
    }

    .contactPdfRow {
        width: 100%;
        gap: 8px;
        margin-bottom: 12px;
    }

    .contactPdfTitle {
        font-size: 0.95rem;
    }

    .contactPdfLinks {
        width: 100%;
        gap: 6px;
    }

    .contactPdfLink {
        flex: 1 1 140px;
        min-height: 34px;
        padding: 6px 8px;
        font-size: 0.85rem;
    }

    .formLabel textarea {
    min-height: 80px;
    max-height: 80px;
    max-width: 70%;
    min-width: 70%;
    overflow-y: auto;
}
.formLabel input, .formLabel textarea {
    width: 70%;
    padding: 8px;
    border: 1px solid var(--colorBorde);
    background-color: transparent;
    color: var(--_texto);
    overflow-y: auto;
    overflow-x: auto;
}

    .contactAlert,
    .contactFormMeta p {
        font-size: 0.85rem;
    }

    .contactTurnstile {
        overflow-x: auto;
    }

    .contenedorJuego {
        width: 100%;
        padding: 14px;
        gap: 8px;
    }

    .contenedorJuego > a,
    #btn-intentar,
    #btn-reiniciar,
    #input-letra {
        font-size: var(--tamanoEnlaceMovileXS);
    }

    #vidas,
    #letrasIncorrectas,
    #mensaje {
        font-size: var(--tamanoTextoMovileXS);
    }

    #tablero {
        font-size: 1.05rem;
        letter-spacing: 0.14em;
        padding: 8px;
    }


    /*Fin del formulario de contacto*/

    .legalSection {
        width: 100%;
        padding: 16px;
        margin-left: auto;
        margin-top: auto;
        position: static;
        top: auto;
        max-height: none;
        overflow-y: visible;
        gap: 14px;
    }

    .legalSection h1 {
        font-size: 1.7rem;
    }

    .legalSection h2 {
        font-size: 1.2rem;
    }

    .legalSection h3 {
        font-size: 1rem;
    }

    .legalSection p,
    .legalSection li,
    .legalSection th,
    .legalSection td {
        font-size: 0.85rem;
        line-height: 1.6;
    }

    .legalSection th,
    .legalSection td {
        padding: 10px;
    }

    .legalSection table {
        min-width: 340px;
    }

    .contenedorFooter {
        flex-direction: column;
        align-items: flex-start;
        gap: 14px;
        padding: 14px;
    }

    .contenedorFooter>p {
        max-width: none;
    }

    .contenedorFooter>p,
    .contenedorFooter .info p,
    .contenedorFooter .privacy a {
        font-size: 0.85rem;
    }

    .contenedorFooter .info {
        width: 100%;
        padding-left: 0;
        padding-top: 12px;
        border-left: none;
        border-top: 1px solid color-mix(in srgb, var(--colorBorde) 55%, transparent);
        gap: 10px;
    }

    .contenedorFooter .privacy {
        width: 100%;
    }
}